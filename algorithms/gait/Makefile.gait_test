# Makefile.gait_test
# 步态测试程序编译配置

CXX = g++
CXXFLAGS = -std=c++17 -Wall -Wextra -O2
LDFLAGS = -lm

# 目录
SRC_DIR = .
BUILD_DIR = build
BIN_DIR = .

# 源文件
SOURCES = \
    $(SRC_DIR)/gait_test.cpp

# 目标文件
TARGET = $(BIN_DIR)/gait_test

# 默认目标
all: $(TARGET)

# 编译主程序
$(TARGET): $(SOURCES)
	@mkdir -p $(BUILD_DIR)
	@echo "编译步态测试程序..."
	$(CXX) $(CXXFLAGS) -I$(SRC_DIR) -o $@ $(SOURCES) $(LDFLAGS)
	@echo "✅ 编译完成: $(TARGET)"

# 清理
clean:
	@echo "清理编译文件..."
	rm -rf $(BUILD_DIR)
	rm -f $(TARGET)
	@echo "✅ 清理完成"

# 运行快速测试
test-quick: $(TARGET)
	@echo "运行快速验证测试..."
	./$(TARGET) --quick

# 运行批量测试
test-batch: $(TARGET)
	@echo "运行批量测试..."
	./$(TARGET) --batch

# 帮助
help:
	@echo "使用方法:"
	@echo "  make -f Makefile.gait_test          # 编译"
	@echo "  make -f Makefile.gait_test clean    # 清理"
	@echo "  make -f Makefile.gait_test test-quick   # 快速测试"
	@echo "  make -f Makefile.gait_test test-batch   # 批量测试"

.PHONY: all clean test-quick test-batch help
